# =============================================================================
# ScraperCar — template de variáveis de ambiente
# -----------------------------------------------------------------------------
# Copie este arquivo para .env e preencha os valores.
# NUNCA comite o .env real — ele contém segredos.
# =============================================================================

# -----------------------------------------------------------------------------
# Banco de dados
# -----------------------------------------------------------------------------
# Dentro do docker-compose, o host é o nome do serviço (ex: postgres).
# Em execução local fora do Compose, troque para localhost.
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/scrapercar
DB_USER=postgres
DB_PASSWORD=troque_esta_senha
DB_NAME=scrapercar

# -----------------------------------------------------------------------------
# Autenticação / segurança
# -----------------------------------------------------------------------------
# Gere com:  openssl rand -base64 64
JWT_SECRET=cole_aqui_uma_string_aleatoria_longa

# Segundos. Access token curto, refresh token longo.
JWT_EXPIRATION=3600
REFRESH_EXPIRATION=604800

# String aleatória que reforça o hash das senhas (defesa extra contra rainbow tables).
# Gere com:  openssl rand -base64 32
# ATENÇÃO: uma vez em produção, NÃO troque — invalida todas as senhas existentes.
PEPPER=cole_aqui_outra_string_aleatoria

# -----------------------------------------------------------------------------
# WppConnect (WhatsApp) — projeto externo
# -----------------------------------------------------------------------------
# Nome da sessão; pode ser qualquer string sem espaços.
WPP_SESSION=scrapercar

# Token de autenticação gerado pelo WppConnect.
# Ver: https://wppconnect.io/docs/server/api
WPP_TOKEN=cole_o_token_gerado_pelo_wppconnect

# URL interna (nome do serviço no Compose).
WPP_URL=http://wppconnect:21465

# Número que enviará as mensagens, no formato DDI+DDD+numero, sem espaços nem símbolos.
# Ex: 5567999998888
WPP_NUMERO=

# -----------------------------------------------------------------------------
# Worker de scraping (FastAPI)
# -----------------------------------------------------------------------------
SCRAPER_URL=http://scraper:8000

# -----------------------------------------------------------------------------
# E-mail (Resend)
# -----------------------------------------------------------------------------
# Token obtido em https://resend.com (dashboard > API Keys).
RESEND_TOKEN=re_cole_sua_chave_aqui

# -----------------------------------------------------------------------------
# Frontend
# -----------------------------------------------------------------------------
# Origens permitidas no CORS do Backend (separadas por vírgula, sem espaços).
URL_FRONTEND=http://localhost:5173,https://scrapercar.augustdev.com.br

# URL do Backend vista pelo Frontend (build-time do Vite).
VITE_API_URL=http://localhost:8080

# -----------------------------------------------------------------------------
# Ambiente
# -----------------------------------------------------------------------------
# true em produção, false em desenvolvimento.
# Altera nível de log, comportamentos de segurança (cookies Secure, etc.).
APP_PRODUCTION=false
